# ─────────────────────────────────────────────
#  GEN_AI_Tasks — Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# OpenAI — used by all 3 tasks for AI generation
OPENAI_API_KEY=sk-your-openai-key-here

# Task 1 — News scraping
NEWSAPI_KEY=your-newsapi-key-here        # https://newsapi.org

# Task 1 — Background images in videos
PEXELS_API_KEY=your-pexels-key-here     # https://www.pexels.com/api/

# Google Generative AI (Gemini)
GOOGLE_API_KEY=your-google-api-key-here  # https://aistudio.google.com/app/apikey
